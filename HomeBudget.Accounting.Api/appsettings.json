{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "AWSSDK": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "WithThreadId", "WithMachineName" ]
  },
  "HealthCheckOptions": {
    "Host": ""
  },
  "DatabaseConnectionOptions": {
    "ConnectionString": "Server=vm2.linux,2233;Database=HomeBudget.Accounting;User ID=sa;Password=*1Secret*1;TrustServerCertificate=True;Connect Timeout=1800",
    "RedisConnectionString": "vm2.linux:6579,allowAdmin=true"
  },
  "ObservabilityOptions": {
    "TelemetryEndpoint": "http://vm2.linux:4317",
    "LogsEndpoint": "http://vm2.linux:4317"
  },
  "EventStoreDb": {
    "Url": "esdb://vm2.linux:2113/?tls=false&keepAliveTimeout=10000&keepAliveInterval=10000",
    "TimeoutInSeconds": 90,
    "RetryAttempts": 5
  },
  "ElasticSearchOptions": {
    "IsEnabled": true,
    "Uri": "http://vm2.linux:9200"
  },
  "ElasticApm": {
    "ServerUrls": "http://vm2.linux:8200",
    "ServiceName": "HomeBudget.Accounting.Api",
    "TransactionSampleRate": 1.0
  },
  "SeqOptions": {
    "IsEnabled": true,
    "Uri": "http://vm2.linux:5341"
  },
  "MongoDbOptions": {
    "ConnectionString": "mongodb://mongoadmin:*SuperSecretPassword*1@vm2.linux:27027/?maxPoolSize=1500&waitQueueTimeoutMS=40000&socketTimeoutMS=10000&connectTimeoutMS=10000&retryWrites=true",
    "PaymentAccounts": "payment_accounts",
    "PaymentsHistory": "payments_history",
    "HandBooks": "handbooks",
    "LedgerDatabase": "ledger"
  },
  "Sentry": {
    "Dsn": ""
  },
  "KafkaOptions": {
    "ProducerSettings": {
      "BootstrapServers": "http://vm2.linux:9092"
    },
    "ConsumerSettings": {
      "BootstrapServers": "http://vm2.linux:9092"
    },
    "AdminSettings": {
      "BootstrapServers": "http://vm2.linux:9092"
    },
    "Topics": {
      "RequestLoggerTopic": "topic-name"
    }
  },
  "PaymentOutboxPublisherOptions": {
    "IsEnabled": true,
    "BatchSize": 25,
    "PollIntervalMilliseconds": 1000,
    "LockTimeoutSeconds": 60,
    "MaxRetryAttempts": 5
  },
  "PaymentInboxOptions": {
    "MaxRetryAttempts": 5
  },
  "UiOriginsUrl": [ "*" ]
}
