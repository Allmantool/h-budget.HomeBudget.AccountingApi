{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "AWSSDK": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "WithThreadId",
      "WithMachineName"
    ]
  },
  "HealthCheckOptions": {
    "Host": ""
  },
  "DatabaseConnectionOptions": {
    "ConnectionString": "",
    "RedisConnectionString": ""
  },
  "EventStoreDb": {
    "Url": "",
    "TimeoutInSeconds": 90,
    "RetryAttempts": 5
  },
  "ObservabilityOptions": {
    "TelemetryEndpoint": "",
    "LogsEndpoint": ""
  },
  "ElasticSearchOptions": {
    "IsEnabled": true,
    "Uri": ""
  },
  "ElasticApm": {
    "ServerUrls": "",
    "ServiceName": "Homebudget.Accounting.Payments.Consumer.Worker",
    "TransactionSampleRate": 1.0
  },
  "SeqOptions": {
    "IsEnabled": true,
    "Uri": ""
  },
  "Sentry": {
    "Dsn": ""
  },
  "MongoDbOptions": {
    "ConnectionString": "",
    "PaymentAccounts": "payment_accounts",
    "PaymentsHistory": "payments_history",
    "HandBooks": "handbooks",
    "LedgerDatabase": "ledger"
  },
  "KafkaOptions": {
    "ProducerSettings": {
      "BootstrapServers": "",
      "MaxPollIntervalMs": 1200000
    },
    "ConsumerSettings": {
      "BootstrapServers": ""
    },
    "AdminSettings": {
      "BootstrapServers": ""
    },
    "Topics": {
      "RequestLoggerTopic": ""
    }
  },
  "NotificationPublisherOptions": {
    "AccountingApiBaseUrl": "http://homebudget-accounting-api"
  },
  "UiOriginsUrl": [
    "*"
  ]
}